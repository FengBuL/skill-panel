{
  "name": "skill-panel",
  "version": "3.8.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:frontend": "vitest run",
    "typecheck": "tsc --noEmit",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:windows": "tauri build --bundles nsis",
    "tauri:build:windows:msi": "tauri build --bundles msi",
    "tauri:build:macos": "tauri build --bundles app,dmg",
    "local:update:macos": "sh scripts/update-local-macos-app.sh",
    "tauri:icons": "tauri icon src-tauri/icons/source.png",
    "visual:qa": "node scripts/visual-qa.mjs",
    "packaging:check": "vitest run src/packaging.config.test.ts",
    "cargo:test": "export PATH=\"$HOME/.cargo/bin:$PATH\"; cd src-tauri && cargo test --lib --bins --tests"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.14.5",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "diff": "^9.0.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/diff": "^7.0.2",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^27.1.0",
    "playwright": "^1.60.0",
    "typescript": "^5.9.2",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
